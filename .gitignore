# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ===========================================
# FRONTEND - Next.js Dependencies
# ===========================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Frontend build outputs
frontend/.next/
frontend/out/
frontend/build/
frontend/*.tsbuildinfo

# Testing
/coverage

# Production
/build

# Misc
.DS_Store
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# ===========================================
# BACKEND - Python
# ===========================================
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.venv/
backend/venv/
backend/env/
backend/.env
backend/.env.*
backend/*.egg-info/
backend/dist/
backend/build/
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/

# ===========================================
# SHARED
# ===========================================
# Environment variables
.env*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/

# next-env.d.ts (only needed at root for Next.js, not in subdirs)
next-env.d.ts
